<Window x:Class="Takt.Fluent.Views.Routine.DictionaryComponent.DictionaryDataForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Takt.Fluent.Localization"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:helpers="clr-namespace:Takt.Fluent.Helpers"
        xmlns:controls="clr-namespace:Takt.Fluent.Controls"
        mc:Ignorable="d"
        d:DesignHeight="600"
        d:DesignWidth="700"
        Title="{Binding Title}" 
        SizeToContent="Manual" 
        WindowStartupLocation="Manual"
        ResizeMode="CanResize" 
        Background="{DynamicResource MaterialDesignPaper}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <helpers:EmptyToVisibilityConverter x:Key="EmptyToVisibilityConverter"/>
        <helpers:StringToBoolConverter x:Key="StringToBoolConverter"/>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            <Setter Property="TextAlignment" Value="Right"/>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="16">
                <!-- 类型代码（只读） -->
                <StackPanel Margin="0,0,0,8" MinHeight="56">
                    <Grid MinHeight="32">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{local:Loc Key=Routine.Dictionary.TypeCode}" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,12,0"/>
                        <controls:TaktTextBox Grid.Column="1" 
                                                    Size="Small"
                                                    VerticalAlignment="Center"
                                                    Text="{Binding TypeCode}"
                                                    IsReadOnly="True"/>
                    </Grid>
                </StackPanel>

                <!-- 数据标签 -->
                <StackPanel Margin="0,0,0,8" MinHeight="56">
                    <Grid MinHeight="32">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,12,0">
                            <Run Text="*" Foreground="{DynamicResource SystemFillColorCriticalBrush}"/>
                            <Run Text="{local:Loc Key=Routine.Dictionary.DataLabel}"/>
                        </TextBlock>
                        <controls:TaktTextBox Grid.Column="1" 
                                                    Size="Small"
                                                    VerticalAlignment="Center"
                                                    Text="{Binding DataLabel, UpdateSourceTrigger=PropertyChanged}"
                                                    HasError="{Binding DataLabelError, Converter={StaticResource StringToBoolConverter}}"/>
                    </Grid>
                    <TextBlock Grid.Column="1" 
                               Style="{StaticResource ErrorTextStyle}" 
                               Text="{Binding DataLabelError}"
                               Visibility="{Binding DataLabelError, Converter={StaticResource EmptyToVisibilityConverter}}"/>
                </StackPanel>

                <!-- 国际化键 -->
                <StackPanel Margin="0,0,0,8" MinHeight="56">
                    <Grid MinHeight="32">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,12,0">
                            <Run Text="*" Foreground="{DynamicResource SystemFillColorCriticalBrush}"/>
                            <Run Text="{local:Loc Key=Routine.Dictionary.I18nKey}"/>
                        </TextBlock>
                        <controls:TaktTextBox Grid.Column="1" 
                                                    Size="Small"
                                                    VerticalAlignment="Center"
                                                    Text="{Binding I18nKey, UpdateSourceTrigger=PropertyChanged}"
                                                    HasError="{Binding I18nKeyError, Converter={StaticResource StringToBoolConverter}}"/>
                    </Grid>
                    <TextBlock Grid.Column="1" 
                               Style="{StaticResource ErrorTextStyle}" 
                               Text="{Binding I18nKeyError}"
                               Visibility="{Binding I18nKeyError, Converter={StaticResource EmptyToVisibilityConverter}}"/>
                </StackPanel>

                <!-- 数据值 -->
                <StackPanel Margin="0,0,0,8" MinHeight="56">
                    <Grid MinHeight="32">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{local:Loc Key=Routine.Dictionary.DataValue}" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,12,0"/>
                        <controls:TaktTextBox Grid.Column="1" 
                                                    Size="Small"
                                                    VerticalAlignment="Center"
                                                    Text="{Binding DataValue, UpdateSourceTrigger=PropertyChanged}"
                                                    HasError="{Binding DataValueError, Converter={StaticResource StringToBoolConverter}}"/>
                    </Grid>
                    <TextBlock Grid.Column="1" 
                               Style="{StaticResource ErrorTextStyle}" 
                               Text="{Binding DataValueError}"
                               Visibility="{Binding DataValueError, Converter={StaticResource EmptyToVisibilityConverter}}"/>
                </StackPanel>

                <!-- 扩展标签 -->
                <StackPanel Margin="0,0,0,8" MinHeight="56">
                    <Grid MinHeight="32">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{local:Loc Key=Routine.Dictionary.ExtLabel}" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,12,0"/>
                        <controls:TaktTextBox Grid.Column="1" 
                                                    Size="Small"
                                                    VerticalAlignment="Center"
                                                    Text="{Binding ExtLabel, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                </StackPanel>

                <!-- 扩展值 -->
                <StackPanel Margin="0,0,0,8" MinHeight="56">
                    <Grid MinHeight="32">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{local:Loc Key=Routine.Dictionary.ExtValue}" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,0,12,0"/>
                        <StackPanel Grid.Column="1">
                            <controls:TaktTextBox 
                                Size="Medium"
                                Text="{Binding ExtValue}"
                                TextWrapping="Wrap" 
                                AcceptsReturn="True" 
                                VerticalScrollBarVisibility="Hidden"
                                MinHeight="80"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <!-- CSS类名 -->
                <StackPanel Margin="0,0,0,8" MinHeight="56">
                    <Grid MinHeight="32">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="CSS类名" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,12,0"/>
                        <controls:TaktTextBox Grid.Column="1" 
                                                    Size="Small"
                                                    VerticalAlignment="Center"
                                                    Text="{Binding CssClass, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                </StackPanel>

                <!-- 列表CSS类名 -->
                <StackPanel Margin="0,0,0,8" MinHeight="56">
                    <Grid MinHeight="32">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="列表CSS类名" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,12,0"/>
                        <controls:TaktTextBox Grid.Column="1" 
                                                    Size="Small"
                                                    VerticalAlignment="Center"
                                                    Text="{Binding ListClass, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                </StackPanel>

                <!-- 排序号 -->
                <StackPanel Margin="0,0,0,8" MinHeight="56">
                    <Grid MinHeight="32">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{local:Loc Key=Routine.Dictionary.OrderNum}" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,12,0"/>
                        <controls:TaktTextBox Grid.Column="1" 
                                                    Size="Small"
                                                    VerticalAlignment="Center"
                                                    Text="{Binding OrderNum, UpdateSourceTrigger=PropertyChanged, StringFormat='{}{0}'}"
                                                    HasError="{Binding OrderNumError, Converter={StaticResource StringToBoolConverter}}"/>
                    </Grid>
                    <TextBlock Grid.Column="1" 
                               Style="{StaticResource ErrorTextStyle}" 
                               Text="{Binding OrderNumError}"
                               Visibility="{Binding OrderNumError, Converter={StaticResource EmptyToVisibilityConverter}}"/>
                </StackPanel>

                <!-- 备注 -->
                <StackPanel Margin="0,0,0,8" MinHeight="56">
                    <Grid MinHeight="32">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{local:Loc Key=common.audit.Remarks}" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,0,12,0"/>
                        <StackPanel Grid.Column="1">
                            <controls:TaktTextBox 
                                Size="Medium"
                                Text="{Binding Remarks}"
                                TextWrapping="Wrap" 
                                AcceptsReturn="True" 
                                VerticalScrollBarVisibility="Hidden"
                                MinHeight="80"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button IsDefault="True" 
                    Command="{Binding SaveCommand}" 
                    Content="{local:Loc Key=common.button.submit}" 
                    Style="{StaticResource DefaultPrimary}"
                    Margin="0,0,12,0"/>
            <Button IsCancel="True" 
                    Content="{local:Loc Key=common.button.cancel}"
                    Style="{StaticResource DefaultInfo}"/>
        </StackPanel>
    </Grid>
</Window>

