<UserControl x:Class="Takt.Fluent.Views.Routine.DictionaryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:Takt.Fluent.Controls"
             xmlns:local="clr-namespace:Takt.Fluent.Localization"
             mc:Ignorable="d"
             d:DesignHeight="720"
             d:DesignWidth="1280">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400" MinWidth="300" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" MinWidth="400" />
        </Grid.ColumnDefinitions>

        <!-- 主表：字典类型 -->
        <controls:TaktDataGrid Grid.Column="0"
                                x:Name="TypeDataGrid"
                                ItemsSource="{Binding DictionaryTypes}"
                                SelectedItem="{Binding SelectedDictionaryType, Mode=TwoWay}"
                                QueryKeyword="{Binding TypeKeyword, Mode=TwoWay}"
                                Loaded="TypeDataGrid_Loaded"
                                QueryPlaceholder="{local:Loc Key=common.placeholder.keywordHint, Param0Key=Routine.Dictionary.TypeKeyword}"
                                QueryButtonText="{local:Loc Key=common.search}"
                                ResetButtonText="{local:Loc Key=common.reset}"
                                ShowToolbarCreate="True"
                                ShowToolbarUpdate="True"
                                ShowToolbarDelete="True"
                                CreateCommand="{Binding CreateTypeCommand}"
                                UpdateCommand="{Binding UpdateTypeCommand}"
                                DeleteCommand="{Binding DeleteTypeCommand}"
                                RowUpdateCommand="{Binding UpdateTypeCommand}"
                                RowDeleteCommand="{Binding DeleteTypeCommand}"
                                ShowToolbarImport="False"
                                ShowToolbarExport="False"
                                ShowAdvancedQueryButton="False"
                                PageIndex="{Binding TypePageIndex, Mode=TwoWay}"
                                PageSize="{Binding TypePageSize, Mode=TwoWay}"
                                TotalCount="{Binding TypeTotalCount}"
                                QueryCommand="{Binding QueryTypesCommand}"
                                ResetCommand="{Binding ResetTypesCommand}"
                                PageChangedCommand="{Binding PageChangedTypesCommand}">
            <controls:TaktDataGrid.Columns>
                <controls:TaktDataGridColumnDefinition Header="{local:Loc Key=Routine.Dictionary.TypeCode}"
                                                        BindingPath="TypeCode"
                                                        Width="150" />
                <controls:TaktDataGridColumnDefinition Header="{local:Loc Key=Routine.Dictionary.TypeName}"
                                                        BindingPath="TypeName"
                                                        Width="*" />
                <controls:TaktDataGridColumnDefinition Header="{local:Loc Key=Routine.Dictionary.OrderNum}"
                                                        BindingPath="OrderNum"
                                                        Width="80" />
                <controls:TaktDataGridColumnDefinition Header="{local:Loc Key=Routine.Dictionary.TypeStatus}"
                                                        BindingPath="TypeStatus"
                                                        Width="100" />
            </controls:TaktDataGrid.Columns>
        </controls:TaktDataGrid>

        <!-- 分割条 -->
        <GridSplitter Grid.Column="1"
                      Width="4"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Background="{DynamicResource MaterialDesignDivider}"
                      ResizeDirection="Columns"
                      ResizeBehavior="PreviousAndNext" />

        <!-- 子表：字典数据 -->
        <controls:TaktDataGrid Grid.Column="2"
                                x:Name="DataDataGrid"
                                ItemsSource="{Binding DictionaryDataList}"
                                SelectedItem="{Binding SelectedDictionaryData, Mode=TwoWay}"
                                QueryKeyword="{Binding DataKeyword, Mode=TwoWay}"
                                Loaded="DataDataGrid_Loaded"
                                QueryPlaceholder="{local:Loc Key=common.placeholder.keywordHint, Param0Key=Routine.Dictionary.DataKeyword}"
                                QueryButtonText="{local:Loc Key=common.search}"
                                ResetButtonText="{local:Loc Key=common.reset}"
                                ShowToolbarCreate="True"
                                ShowToolbarUpdate="True"
                                ShowToolbarDelete="True"
                                CreateCommand="{Binding CreateDataCommand}"
                                UpdateCommand="{Binding UpdateDataCommand}"
                                DeleteCommand="{Binding DeleteDataCommand}"
                                RowUpdateCommand="{Binding UpdateDataCommand}"
                                RowDeleteCommand="{Binding DeleteDataCommand}"
                                ShowToolbarImport="False"
                                ShowToolbarExport="False"
                                ShowAdvancedQueryButton="False"
                                PageIndex="{Binding DataPageIndex, Mode=TwoWay}"
                                PageSize="{Binding DataPageSize, Mode=TwoWay}"
                                TotalCount="{Binding DataTotalCount}"
                                QueryCommand="{Binding QueryDataCommand}"
                                ResetCommand="{Binding ResetDataCommand}"
                                PageChangedCommand="{Binding PageChangedDataCommand}">
            <controls:TaktDataGrid.Columns>
                <controls:TaktDataGridColumnDefinition Header="{local:Loc Key=Routine.Dictionary.DataLabel}"
                                                        BindingPath="DataLabel"
                                                        Width="*" />
                <controls:TaktDataGridColumnDefinition Header="{local:Loc Key=Routine.Dictionary.I18nKey}"
                                                        BindingPath="I18nKey"
                                                        Width="200" />
                <controls:TaktDataGridColumnDefinition Header="{local:Loc Key=Routine.Dictionary.DataValue}"
                                                        BindingPath="DataValue"
                                                        Width="200" />
                <controls:TaktDataGridColumnDefinition Header="{local:Loc Key=Routine.Dictionary.OrderNum}"
                                                        BindingPath="OrderNum"
                                                        Width="80" />
                <controls:TaktDataGridColumnDefinition Header="{local:Loc Key=common.audit.Remarks}"
                                                        BindingPath="Remarks"
                                                        Width="200" />
            </controls:TaktDataGrid.Columns>
        </controls:TaktDataGrid>
    </Grid>
</UserControl>

