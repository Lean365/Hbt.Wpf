<UserControl x:Class="Takt.Fluent.Views.Dashboard.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
             xmlns:local="clr-namespace:Takt.Fluent.Localization"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <ScrollViewer Margin="0"
                  Padding="0,0,24,0"
                  VerticalScrollBarVisibility="Auto"
                  CanContentScroll="False">
        <StackPanel Margin="0">
            <Border Padding="24"
                    Margin="0"
                    Background="{DynamicResource ApplicationBackgroundBrush}">
                <StackPanel>
                    <TextBlock Text="{Binding GreetingText}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>

                    <TextBlock Text="{local:Loc Key=Common.CompanyTagline}"
                               FontSize="14"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                               Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <UniformGrid Columns="4" Margin="0,16,0,0">
                <Border Padding="20"
                        Margin="0,0,8,0"
                        BorderThickness="1"
                        CornerRadius="8"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <fa:IconBlock Icon="Users"
                                         IconFont="Solid"
                                         Width="24"
                                         Height="24"
                                         Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <TextBlock Text="在线用户"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Margin="8,0,0,0"/>
                        </StackPanel>
                        <TextBlock Text="{Binding OnlineUsers}"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <Border Padding="20"
                        Margin="8,0,8,0"
                        BorderThickness="1"
                        CornerRadius="8"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <fa:IconBlock Icon="Box"
                                         IconFont="Solid"
                                         Width="24"
                                         Height="24"
                                         Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <TextBlock Text="今日入库"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Margin="8,0,0,0"/>
                        </StackPanel>
                        <TextBlock Text="{Binding TodayInbound}"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <Border Padding="20"
                        Margin="8,0,8,0"
                        BorderThickness="1"
                        CornerRadius="8"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <fa:IconBlock Icon="Truck"
                                         IconFont="Solid"
                                         Width="24"
                                         Height="24"
                                         Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <TextBlock Text="今日出库"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Margin="8,0,0,0"/>
                        </StackPanel>
                        <TextBlock Text="{Binding TodayOutbound}"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <Border Padding="20"
                        Margin="8,0,0,0"
                        BorderThickness="1"
                        CornerRadius="8"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <fa:IconBlock Icon="UserCheck"
                                         IconFont="Solid"
                                         Width="24"
                                         Height="24"
                                         Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <TextBlock Text="今日来访"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Margin="8,0,0,0"/>
                        </StackPanel>
                        <TextBlock Text="{Binding TodayVisitors}"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
