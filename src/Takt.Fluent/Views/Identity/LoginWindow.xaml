<Window x:Class="Takt.Fluent.Views.Identity.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
        xmlns:helpers="clr-namespace:Takt.Fluent.Helpers"
        xmlns:local="clr-namespace:Takt.Fluent.Localization"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="{local:Loc Key=Login.Title}"
        Height="600"
        Width="900"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="{DynamicResource LayerFillColorDefaultBrush}">
    
    <Window.Resources>
        <helpers:EmptyToVisibilityConverter x:Key="EmptyToVisibilityConverter" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <helpers:InvertedBooleanToVisibilityConverter x:Key="InvertedBooleanToVisibilityConverter" />
        <helpers:StringToBoolConverter x:Key="StringToBoolConverter" />
        
        <Style TargetType="fa:IconBlock">
            <Setter Property="IconFont" Value="Solid"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
        </Style>
        <Style x:Key="CloseButtonStyle" TargetType="Button" BasedOn="{StaticResource CirclePlainDanger}">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
            <Setter Property="materialDesign:RippleAssist.IsCentered" Value="True"/>
            <Setter Property="materialDesign:RippleAssist.Feedback" Value="{x:Null}"/>
        </Style>
    </Window.Resources>
    
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="1.2*"/>
                </Grid.ColumnDefinitions>
                
                <!-- 左侧品牌区域 -->
                <Border x:Name="BrandAreaBorder"
                        Grid.Column="0">
                    <StackPanel VerticalAlignment="Center" 
                               HorizontalAlignment="Center"
                               Margin="60">
                        <Image Source="pack://application:,,,/Assets/takt-res.png"
                               Width="120" 
                               Height="120"
                               Margin="0,0,0,40"
                               Stretch="Uniform"/>
                        <TextBlock Text="{local:Loc Key=Common.CompanyName}"
                                   FontSize="32" 
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   Margin="0,0,0,16"/>
                        <TextBlock Text="{local:Loc Key=Common.CompanySlogan}"
                                   FontSize="18" 
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Opacity="0.85"/>
                        <TextBlock Text="{local:Loc Key=Common.CompanyTagline}" 
                                   FontSize="14" 
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,20,0,0"
                                   Opacity="0.75"/>
                    </StackPanel>
                </Border>
                
                <!-- 分隔线 -->
                <Rectangle Grid.Column="1" 
                           Width="1" 
                           Fill="{DynamicResource ControlStrokeColorSecondaryBrush}"/>
                
                <!-- 右侧登录区域 -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 顶部操作按钮 -->
                    <StackPanel Grid.Row="0"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,4,4,0">
                        <Button x:Name="LanguageButton"
                                Style="{StaticResource MaterialDesignIconButton}"
                                Width="36"
                                Height="36"
                                Margin="0,0,4,0"
                                ToolTip="{Binding LanguageToolTip}"
                                Click="LanguageButton_Click">
                            <fa:IconBlock x:Name="LanguageIcon" Icon="{x:Static fa:IconChar.Globe}" FontSize="18"/>
                            <Button.ContextMenu>
                                <ContextMenu x:Name="LanguageContextMenu"
                                             Opened="LanguageContextMenu_Opened">
                                    <ContextMenu.ItemContainerStyle>
                                        <Style TargetType="MenuItem">
                                            <Setter Property="Header" Value="{Binding Name}"/>
                                            <Setter Property="IsCheckable" Value="True"/>
                                            <EventSetter Event="Click" Handler="LanguageMenuItem_Click"/>
                                        </Style>
                                    </ContextMenu.ItemContainerStyle>
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>

                        <Button x:Name="ThemeButton"
                                Style="{StaticResource MaterialDesignIconButton}"
                                Width="36"
                                Height="36"
                                Margin="4,0,0,0"
                                ToolTip="{Binding ThemeToolTip}"
                                Click="ThemeButton_Click">
                            <fa:IconBlock x:Name="ThemeIcon" Icon="{x:Static fa:IconChar.Palette}" FontSize="18"/>
                        </Button>

                        <Button Style="{StaticResource DefaultDangerNoSmall}"
                                ToolTip="{local:Loc Key=Common.Close}"
                                Click="CloseButton_Click">
                            <fa:IconBlock Icon="{x:Static fa:IconChar.Xmark}"
                                          FontSize="18"
                                          Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                        </Button>
                    </StackPanel>

                    <!-- 登录表单 -->
                    <Border x:Name="LoginFormBorder"
                            Grid.Row="1"
                            Margin="32,8,32,32"
                            Padding="48,8,48,48"
                            CornerRadius="16"
                            Background="{x:Null}"
                            BorderBrush="{x:Null}">
                            <StackPanel VerticalAlignment="Center">
                        <StackPanel>
                            <StackPanel>
                                <TextBlock Text="{local:Loc Key=Login.Welcome}"
                                           FontSize="28" 
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                <TextBlock Text="{local:Loc Key=Login.Description}"
                                           FontSize="14"
                                           Margin="0,4,0,0"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           Opacity="0.8"/>
                            </StackPanel>

                            <StackPanel Margin="0,20,0,0" MinHeight="56">
                                <Grid>
                                    <fa:IconBlock Icon="{x:Static fa:IconChar.User}"
                                                  FontSize="16"
                                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                  HorizontalAlignment="Left"
                                                  VerticalAlignment="Center"
                                                  Margin="12,0,0,0"
                                                  IsHitTestVisible="False"/>
                                    <TextBox x:Name="UsernameTextBox"
                                             Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             materialDesign:HintAssist.Hint="{local:Loc Key=Login.Username}"
                                             materialDesign:HintAssist.IsFloating="True"
                                             materialDesign:HintAssist.Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                             materialDesign:TextFieldAssist.DecorationVisibility="Collapsed"
                                             Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                             FontSize="14"
                                             Padding="36,8,12,8"/>
                                </Grid>
                                <TextBlock Text="{Binding UsernameError}"
                                           Style="{StaticResource LoginErrorTextStyle}"
                                           Margin="36,8,0,0"
                                           Visibility="{Binding UsernameError, Converter={StaticResource EmptyToVisibilityConverter}}"/>
                            </StackPanel>

                            <StackPanel Margin="0,20,0,0" MinHeight="56">
                                <Grid>
                                    <fa:IconBlock Icon="{x:Static fa:IconChar.Lock}"
                                                  FontSize="16"
                                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                  HorizontalAlignment="Left"
                                                  VerticalAlignment="Center"
                                                  Margin="12,0,0,0"
                                                  IsHitTestVisible="False"/>
                                    <PasswordBox x:Name="PasswordBox"
                                                 PasswordChanged="PasswordBox_PasswordChanged"
                                                 Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                                 materialDesign:HintAssist.Hint="{local:Loc Key=Login.Password}"
                                                 materialDesign:HintAssist.IsFloating="True"
                                                 materialDesign:HintAssist.Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                 materialDesign:TextFieldAssist.DecorationVisibility="Collapsed"
                                                 Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                 FontSize="14"
                                                 Padding="36,8,12,8"/>
                                </Grid>
                                <TextBlock Text="{Binding PasswordError}"
                                           Style="{StaticResource LoginErrorTextStyle}"
                                           Margin="36,8,0,0"
                                           Visibility="{Binding PasswordError, Converter={StaticResource EmptyToVisibilityConverter}}"/>
                            </StackPanel>

                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0"
                                          Content="{local:Loc Key=Login.RememberMe}" 
                                          IsChecked="{Binding RememberMe}"
                                          Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                          VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Text="{local:Loc Key=Login.Forgot}"
                                           Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                                           Cursor="Hand"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="TextDecorations" Value="{x:Null}"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource AccentFillColorSecondaryBrush}"/>
                                                    <Setter Property="TextDecorations" Value="Underline"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>

                            <!-- 统一错误消息：仅用于服务端/系统错误 -->
                            <Border Style="{StaticResource ErrorMessageBorderStyle}"
                                    Visibility="{Binding ErrorMessage, Converter={StaticResource EmptyToVisibilityConverter}}">
                                <StackPanel Orientation="Horizontal">
                                    <fa:IconBlock Icon="{x:Static fa:IconChar.CircleExclamation}"
                                                  Foreground="{DynamicResource SystemFillColorCriticalBrush}"/>
                                    <TextBlock Text="{Binding ErrorMessage}" 
                                               Style="{StaticResource ErrorMessageTextStyle}"/>
                                </StackPanel>
                            </Border>

                            <Button Height="48"
                                    MinHeight="48"
                                    MaxHeight="48"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Command="{Binding LoginCommand}"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Margin="0,24,0,0">
                                <Grid>
                                    <Grid Visibility="{Binding IsLoading, Converter={StaticResource InvertedBooleanToVisibilityConverter}}">
                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Center" 
                                                    VerticalAlignment="Center">
                                            <fa:IconBlock Icon="{x:Static fa:IconChar.Check}" Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}"/>
                                            <TextBlock Text="{local:Loc Key=Login.Button}"
                                                       Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}"
                                                       FontSize="16"
                                                       VerticalAlignment="Center"
                                                       Margin="8,0,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                    <Grid Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Center" 
                                                    VerticalAlignment="Center">
                                            <ProgressBar Width="28"
                                                        Height="28"
                                                        Style="{StaticResource MaterialDesignCircularProgressBar}"
                                                        IsIndeterminate="True"/>
                                            <TextBlock Text="{local:Loc Key=Login.Loading}"
                                                       Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}"
                                                       FontSize="16"
                                                       VerticalAlignment="Center"
                                                       Margin="8,0,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Button>
                        </StackPanel>
                            </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Margin="0,0,0,16">
                <TextBlock Text="©"
                           FontSize="12"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                <TextBlock Text="{Binding Source={x:Static sys:DateTime.Now}, Path=Year}"
                           FontSize="12"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Margin="4,0,0,0"/>
                <TextBlock Text="{local:Loc Key=Common.CopyrightShort}"
                           FontSize="12"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Margin="4,0,0,0"/>
            </StackPanel>
        </Grid>
</Window>
