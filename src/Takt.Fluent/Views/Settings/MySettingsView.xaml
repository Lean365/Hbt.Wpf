<UserControl x:Class="Takt.Fluent.Views.Settings.MySettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Takt.Fluent.Controls"
             xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
             xmlns:local="clr-namespace:Takt.Fluent.Localization"
             xmlns:helpers="clr-namespace:Takt.Fluent.Helpers"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800">
    <UserControl.Resources>
        <helpers:EmptyToVisibilityConverter x:Key="EmptyToVisibilityConverter" />

        <Style x:Key="SettingsCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style x:Key="SettingTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="SettingDescriptionStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="LineHeight" Value="20"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>

        <Style x:Key="MessageCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource ApplicationBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <controls:TaktPageHeader Grid.Row="0"
                              Margin="0,0,0,40"
                              Title="{local:Loc Key=Settings.Customize.Title}"
                              Description="{local:Loc Key=Settings.Customize.Description}" />

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="0,0,24,0"
                      Background="{DynamicResource ApplicationBackgroundBrush}">
            <StackPanel>

                <Border Style="{StaticResource MessageCardStyle}"
                        Background="{DynamicResource SystemFillColorCautionBackgroundBrush}"
                        BorderBrush="{DynamicResource SystemFillColorCriticalBrush}"
                        BorderThickness="1"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource EmptyToVisibilityConverter}}"
                        Margin="0,0,0,16">
                    <StackPanel Orientation="Horizontal">
                        <fa:IconBlock Icon="CircleExclamation"
                                     IconFont="Solid"
                                     Width="20"
                                     Height="20"
                                     Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                                     VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding ErrorMessage}"
                                   FontSize="14"
                                   Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource MessageCardStyle}"
                        Background="{DynamicResource SystemFillColorCautionBackgroundBrush}"
                        BorderBrush="{DynamicResource AccentFillColorDefaultBrush}"
                        BorderThickness="1"
                        Visibility="{Binding SuccessMessage, Converter={StaticResource EmptyToVisibilityConverter}}"
                        Margin="0,0,0,16">
                    <StackPanel Orientation="Horizontal">
                        <fa:IconBlock Icon="CircleCheck"
                                     IconFont="Solid"
                                     Width="20"
                                     Height="20"
                                     Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                                     VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding SuccessMessage}"
                                   FontSize="14"
                                   Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0"/>
                    </StackPanel>
                </Border>

                <TextBlock Text="{local:Loc Key=Settings.Customize.AppearanceAndBehavior}"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           Margin="0,0,0,16"/>

                <Border Style="{StaticResource SettingsCardStyle}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <fa:IconBlock Icon="Palette"
                                         IconFont="Solid"
                                         Width="24"
                                         Height="24"
                                         Foreground="{DynamicResource AccentFillColorDefaultBrush}"/>
                            <TextBlock Text="{local:Loc Key=Settings.Customize.ThemeMode}" Style="{StaticResource SettingTitleStyle}" Margin="12,0,0,0"/>
                        </StackPanel>

                        <TextBlock Text="{local:Loc Key=Settings.Customize.ThemeMode.Description}"
                                   Style="{StaticResource SettingDescriptionStyle}"/>

                        <ComboBox ItemsSource="{Binding AvailableThemes}"
                                  SelectedItem="{Binding SelectedTheme, Mode=TwoWay}"
                                  DisplayMemberPath="DisplayName"
                                  MinWidth="200"
                                  MaxWidth="300"
                                  HorizontalAlignment="Left"
                                  Style="{StaticResource MaterialDesignComboBox}"
                                  Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                  Background="{DynamicResource ControlFillColorDefaultBrush}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SettingsCardStyle}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <fa:IconBlock Icon="Language"
                                         IconFont="Solid"
                                         Width="24"
                                         Height="24"
                                         Foreground="{DynamicResource AccentFillColorDefaultBrush}"/>
                            <TextBlock Text="{local:Loc Key=Settings.Customize.Language}" Style="{StaticResource SettingTitleStyle}" Margin="12,0,0,0"/>
                        </StackPanel>

                        <TextBlock Text="{local:Loc Key=Settings.Customize.Language.Description}"
                                   Style="{StaticResource SettingDescriptionStyle}"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <ComboBox Grid.Column="0"
                                      ItemsSource="{Binding AvailableLanguages}"
                                      SelectedItem="{Binding SelectedLanguage, Mode=TwoWay}"
                                      DisplayMemberPath="Name"
                                      MinWidth="200"
                                      MaxWidth="300"
                                      HorizontalAlignment="Left"
                                      Style="{StaticResource MaterialDesignComboBox}"
                                      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                      Background="{DynamicResource ControlFillColorDefaultBrush}"/>

                            <Button Grid.Column="1"
                                    Content="{local:Loc Key=common.button.apply}"
                                    MinWidth="100"
                                    Style="{StaticResource DefaultPrimary}"
                                    Command="{Binding SaveLanguageCommand}"
                                    Margin="16,0,0,0"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <TextBlock Text="{local:Loc Key=Settings.Customize.FontSettings}"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           Margin="0,16,0,16"/>

                <Border Style="{StaticResource SettingsCardStyle}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <fa:IconBlock Icon="Font"
                                         IconFont="Solid"
                                         Width="24"
                                         Height="24"
                                         Foreground="{DynamicResource AccentFillColorDefaultBrush}"/>
                            <TextBlock Text="{local:Loc Key=Settings.Customize.FontSettings}" Style="{StaticResource SettingTitleStyle}" Margin="12,0,0,0"/>
                        </StackPanel>

                        <TextBlock Text="{local:Loc Key=Settings.Customize.FontFamily.Description}"
                                   Style="{StaticResource SettingDescriptionStyle}"/>

                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{local:Loc Key=Settings.Customize.FontFamily}"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           Margin="0,0,0,4"/>
                                <ComboBox x:Name="FontFamilyComboBox"
                                          ItemsSource="{Binding AvailableFontFamilies}"
                                          SelectedItem="{Binding SelectedFontFamily, Mode=TwoWay}"
                                          DisplayMemberPath="Source"
                                          Style="{StaticResource MaterialDesignComboBox}"
                                          Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                          Background="{DynamicResource ControlFillColorDefaultBrush}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{local:Loc Key=Settings.Customize.FontSize}"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           Margin="0,0,0,4"/>
                                <ComboBox x:Name="FontSizeComboBox"
                                          ItemsSource="{Binding AvailableFontSizes}"
                                          SelectedItem="{Binding SelectedFontSize, Mode=TwoWay}"
                                          Style="{StaticResource MaterialDesignComboBox}"
                                          Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                          Background="{DynamicResource ControlFillColorDefaultBrush}"/>
                            </StackPanel>

                            <Button Grid.Column="3"
                                    Content="{local:Loc Key=common.button.apply}"
                                    MinWidth="100"
                                    Style="{StaticResource DefaultPrimary}"
                                    Command="{Binding SaveFontFamilyCommand}"
                                    VerticalAlignment="Bottom"
                                    Margin="16,0,0,0"/>
                        </Grid>

                        <Border BorderThickness="1"
                                CornerRadius="4"
                                Padding="12"
                                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                Margin="0,12,0,0">
                            <TextBlock FontFamily="{Binding SelectedFontFamily, Mode=OneWay, FallbackValue={x:Static SystemFonts.MessageFontFamily}}"
                                       FontSize="{Binding SelectedFontSize, Mode=OneWay, FallbackValue=14}"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       TextWrapping="Wrap">
                                <Run Text="{local:Loc Key=Settings.Customize.FontPreview}"/>
                                <Run Text="The quick brown fox jumps over the lazy dog. 快速棕色狐狸跳过懒狗。"/>
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>