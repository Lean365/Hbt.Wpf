<UserControl x:Class="Takt.Fluent.Views.Logistics.Serials.SerialInboundView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:Takt.Fluent.Controls"
             xmlns:local="clr-namespace:Takt.Fluent.Localization"
             mc:Ignorable="d"
             d:DesignHeight="720"
             d:DesignWidth="1280">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400" MinWidth="300" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" MinWidth="400" />
        </Grid.ColumnDefinitions>

        <!-- 主表：产品序列号 -->
        <controls:TaktDataGrid Grid.Column="0"
                                x:Name="SerialDataGrid"
                                ItemsSource="{Binding ProdSerials}"
                                SelectedItem="{Binding SelectedProdSerial, Mode=TwoWay}"
                                QueryKeyword="{Binding SerialKeyword, Mode=TwoWay}"
                                QueryPlaceholder="{local:Loc Key=common.placeholder.keywordHint, Param0Key=Logistics.Serial.SerialKeyword}"
                                ShowToolbarCreate="True"
                                ShowToolbarUpdate="True"
                                ShowToolbarDelete="True"
                                CreateCommand="{Binding CreateSerialCommand}"
                                UpdateCommand="{Binding UpdateSerialCommand}"
                                DeleteCommand="{Binding DeleteSerialCommand}"
                                RowUpdateCommand="{Binding UpdateSerialCommand}"
                                RowDeleteCommand="{Binding DeleteSerialCommand}"
                                PageIndex="{Binding SerialPageIndex, Mode=TwoWay}"
                                PageSize="{Binding SerialPageSize, Mode=TwoWay}"
                                TotalCount="{Binding SerialTotalCount}"
                                QueryCommand="{Binding QuerySerialsCommand}"
                                ResetCommand="{Binding ResetSerialsCommand}"
                                PageChangedCommand="{Binding PageChangedSerialsCommand}"
                                Loaded="SerialDataGrid_Loaded">
            <controls:TaktDataGrid.Columns>
                <controls:TaktDataGridColumnDefinition Header="{local:Loc Key=Logistics.Serial.MaterialCode}" BindingPath="MaterialCode" Width="150" />
                <controls:TaktDataGridColumnDefinition Header="{local:Loc Key=Logistics.Serial.ModelCode}" BindingPath="ModelCode" Width="150" />
                <controls:TaktDataGridColumnDefinition Header="{local:Loc Key=Logistics.Serial.DestCode}" BindingPath="DestCode" Width="100" />
            </controls:TaktDataGrid.Columns>
        </controls:TaktDataGrid>

        <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Center" VerticalAlignment="Stretch" />

        <!-- 子表：序列号入库记录 -->
        <controls:TaktDataGrid Grid.Column="2"
                                x:Name="InboundDataGrid"
                                ItemsSource="{Binding ProdSerialInbounds}"
                                SelectedItem="{Binding SelectedProdSerialInbound, Mode=TwoWay}"
                                QueryKeyword="{Binding InboundKeyword, Mode=TwoWay}"
                                QueryPlaceholder="{local:Loc Key=common.placeholder.keywordHint, Param0Key=Logistics.SerialInbound.InboundKeyword}"
                                ShowToolbarCreate="True"
                                ShowToolbarUpdate="True"
                                ShowToolbarDelete="True"
                                CreateCommand="{Binding CreateInboundCommand}"
                                UpdateCommand="{Binding UpdateInboundCommand}"
                                DeleteCommand="{Binding DeleteInboundCommand}"
                                RowUpdateCommand="{Binding UpdateInboundCommand}"
                                RowDeleteCommand="{Binding DeleteInboundCommand}"
                                PageIndex="{Binding InboundPageIndex, Mode=TwoWay}"
                                PageSize="{Binding InboundPageSize, Mode=TwoWay}"
                                TotalCount="{Binding InboundTotalCount}"
                                QueryCommand="{Binding QueryInboundsCommand}"
                                ResetCommand="{Binding ResetInboundsCommand}"
                                PageChangedCommand="{Binding PageChangedInboundsCommand}"
                                Loaded="InboundDataGrid_Loaded">
            <controls:TaktDataGrid.Columns>
                <controls:TaktDataGridColumnDefinition Header="{local:Loc Key=Logistics.SerialInbound.InboundNo}" BindingPath="InboundNo" Width="150" />
                <controls:TaktDataGridColumnDefinition Header="{local:Loc Key=Logistics.SerialInbound.SerialNumber}" BindingPath="SerialNumber" Width="150" />
                <controls:TaktDataGridColumnDefinition Header="{local:Loc Key=Logistics.SerialInbound.Quantity}" BindingPath="Quantity" Width="100" />
                <controls:TaktDataGridColumnDefinition Header="{local:Loc Key=Logistics.SerialInbound.InboundDate}" BindingPath="InboundDate" Width="150" />
                <controls:TaktDataGridColumnDefinition Header="{local:Loc Key=Logistics.SerialInbound.Warehouse}" BindingPath="Warehouse" Width="120" />
                <controls:TaktDataGridColumnDefinition Header="{local:Loc Key=Logistics.SerialInbound.Location}" BindingPath="Location" Width="120" />
            </controls:TaktDataGrid.Columns>
        </controls:TaktDataGrid>
    </Grid>
</UserControl>

