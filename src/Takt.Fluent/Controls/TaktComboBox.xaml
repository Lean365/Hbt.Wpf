<UserControl x:Class="Takt.Fluent.Controls.TaktComboBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:helpers="clr-namespace:Takt.Fluent.Helpers"
             mc:Ignorable="d"
             d:DesignHeight="36"
             d:DesignWidth="200">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <helpers:InverseBoolConverter x:Key="InverseBoolConverter"/>
        
        <Style x:Key="SmallTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="MaxHeight" Value="32"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            <Setter Property="materialDesign:HintAssist.Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
            <Setter Property="materialDesign:TextFieldAssist.DecorationVisibility" Value="Collapsed"/>
        </Style>
        <Style x:Key="MediumTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="MaxHeight" Value="36"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            <Setter Property="materialDesign:HintAssist.Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
            <Setter Property="materialDesign:TextFieldAssist.DecorationVisibility" Value="Collapsed"/>
        </Style>
        <Style x:Key="LargeTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
            <Setter Property="Height" Value="40"/>
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="MaxHeight" Value="40"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            <Setter Property="materialDesign:HintAssist.Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
            <Setter Property="materialDesign:TextFieldAssist.DecorationVisibility" Value="Collapsed"/>
        </Style>
    </UserControl.Resources>
    
    <Grid>
        <!-- 单选模式：使用 TextBox + Popup -->
        <Grid x:Name="SingleSelectContainer"
              Visibility="{Binding SelectionMode, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource InverseBoolConverter}}">
            <TextBox x:Name="SingleSelectTextBox"
                     IsReadOnly="True"
                     Cursor="Hand"
                     materialDesign:HintAssist.Hint="{Binding Hint, RelativeSource={RelativeSource AncestorType=UserControl}}"
                     PreviewMouseLeftButtonDown="SingleSelectTextBox_PreviewMouseLeftButtonDown"
                     GotFocus="SingleSelectTextBox_GotFocus"/>
            <!-- 错误边框覆盖层：当 HasError 为 true 时显示红色边框 -->
            <Border x:Name="SingleSelectErrorBorder"
                    BorderBrush="{DynamicResource SystemFillColorCriticalBrush}"
                    BorderThickness="2"
                    CornerRadius="4"
                    IsHitTestVisible="False"
                    Visibility="{Binding HasError, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            
            <Popup x:Name="SingleSelectPopup"
                   Placement="Bottom"
                   PlacementTarget="{Binding ElementName=SingleSelectTextBox}"
                   StaysOpen="False"
                   PopupAnimation="Slide"
                   AllowsTransparency="True"
                   Opened="SingleSelectPopup_Opened"
                   Closed="SingleSelectPopup_Closed">
                <Border Background="{DynamicResource MaterialDesignPaper}"
                        BorderBrush="{DynamicResource MaterialDesignDivider}"
                        BorderThickness="1"
                        CornerRadius="4"
                        MaxHeight="300"
                        MinWidth="{Binding ActualWidth, ElementName=SingleSelectTextBox}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <!-- 搜索框 -->
                        <TextBox x:Name="SingleFilterTextBox"
                                 Grid.Row="0"
                                 Margin="8"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 materialDesign:HintAssist.Hint="搜索..."
                                 materialDesign:HintAssist.IsFloating="True"
                                 materialDesign:HintAssist.Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                 materialDesign:TextFieldAssist.DecorationVisibility="Collapsed"
                                 Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                 Text="{Binding FilterText, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 TextChanged="FilterTextBox_TextChanged"/>
                        
                        <!-- 列表 -->
                        <ListBox x:Name="SingleSelectListBox"
                                 Grid.Row="1"
                                 SelectionMode="Single"
                                 ItemsSource="{Binding FilteredItemsSource, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                 SelectedItem="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}"
                                 DisplayMemberPath="{Binding DisplayMemberPath, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                 ItemTemplate="{Binding ItemTemplate, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                 ItemContainerStyle="{Binding ItemContainerStyle, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                 MaxHeight="250"
                                 VirtualizingPanel.IsVirtualizing="True"
                                 VirtualizingPanel.VirtualizationMode="Recycling"
                                 ScrollViewer.CanContentScroll="True"
                                 SelectionChanged="SingleSelectListBox_SelectionChanged"/>
                    </Grid>
                </Border>
            </Popup>
        </Grid>
        
        <!-- 多选模式：使用 TextBox + Popup -->
        <Grid x:Name="MultiSelectContainer"
              Visibility="{Binding SelectionMode, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBox x:Name="MultiSelectTextBox"
                     IsReadOnly="True"
                     Cursor="Hand"
                     materialDesign:HintAssist.Hint="{Binding Hint, RelativeSource={RelativeSource AncestorType=UserControl}}"
                     PreviewMouseLeftButtonDown="MultiSelectTextBox_PreviewMouseLeftButtonDown"
                     GotFocus="MultiSelectTextBox_GotFocus"/>
            <!-- 错误边框覆盖层：当 HasError 为 true 时显示红色边框 -->
            <Border x:Name="MultiSelectErrorBorder"
                    BorderBrush="{DynamicResource SystemFillColorCriticalBrush}"
                    BorderThickness="2"
                    CornerRadius="4"
                    IsHitTestVisible="False"
                    Visibility="{Binding HasError, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            
            <Popup x:Name="MultiSelectPopup"
                   Placement="Bottom"
                   PlacementTarget="{Binding ElementName=MultiSelectTextBox}"
                   StaysOpen="False"
                   PopupAnimation="Slide"
                   AllowsTransparency="True"
                   Opened="MultiSelectPopup_Opened"
                   Closed="MultiSelectPopup_Closed">
                <Border Background="{DynamicResource MaterialDesignPaper}"
                        BorderBrush="{DynamicResource MaterialDesignDivider}"
                        BorderThickness="1"
                        CornerRadius="4"
                        MaxHeight="300"
                        MinWidth="{Binding ActualWidth, ElementName=MultiSelectTextBox}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <!-- 搜索框 -->
                        <TextBox x:Name="MultiFilterTextBox"
                                 Grid.Row="0"
                                 Margin="8"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 materialDesign:HintAssist.Hint="搜索..."
                                 materialDesign:HintAssist.IsFloating="True"
                                 materialDesign:HintAssist.Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                 materialDesign:TextFieldAssist.DecorationVisibility="Collapsed"
                                 Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                 Text="{Binding FilterText, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 TextChanged="FilterTextBox_TextChanged"/>
                        
                        <!-- 列表 -->
                        <ListBox x:Name="MultiSelectListBox"
                                 Grid.Row="1"
                                 SelectionMode="Multiple"
                                 ItemsSource="{Binding FilteredItemsSource, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                 DisplayMemberPath="{Binding DisplayMemberPath, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                 ItemTemplate="{Binding ItemTemplate, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                 ItemContainerStyle="{Binding ItemContainerStyle, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                 MaxHeight="250"
                                 VirtualizingPanel.IsVirtualizing="True"
                                 VirtualizingPanel.VirtualizationMode="Recycling"
                                 ScrollViewer.CanContentScroll="True"
                                 SelectionChanged="MultiSelectListBox_SelectionChanged"/>
                    </Grid>
                </Border>
            </Popup>
        </Grid>
    </Grid>
</UserControl>

