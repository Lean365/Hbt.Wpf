<UserControl x:Class="Hbt.Fluent.Views.Dashboard.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
             xmlns:local="clr-namespace:Hbt.Fluent.Localization"
             Foreground="{DynamicResource TextFillColorPrimaryBrush}"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <ScrollViewer Grid.Row="0" Margin="0,0,0,24" Padding="0,0,24,0">
            <StackPanel HorizontalAlignment="Stretch">
            <!-- 欢迎信息 -->
            <Border Background="{DynamicResource CardFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="24"
                    Margin="10"
                    HorizontalAlignment="Stretch">
                <StackPanel>
                    <TextBlock x:Name="GreetingTextBlock"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="{local:Loc Key=dashboard.welcome}"
                               FontSize="14"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- 统计卡片 -->
            <UniformGrid Columns="4"
                         Margin="10"
                         HorizontalAlignment="Stretch">
                <!-- 在线用户 -->
                <Border Background="{DynamicResource CardFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="20"
                        Margin="0,0,8,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <fa:IconBlock Icon="Users"
                                         IconFont="Solid"
                                         Width="24"
                                         Height="24"
                                         Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                                         Margin="0,0,8,0"/>
                            <TextBlock Text="在线用户"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="0"
                                   FontSize="28"
                                   FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- 今日入库 -->
                <Border Background="{DynamicResource CardFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="20"
                        Margin="8,0,8,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <fa:IconBlock Icon="Box"
                                         IconFont="Solid"
                                         Width="24"
                                         Height="24"
                                         Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                                         Margin="0,0,8,0"/>
                            <TextBlock Text="今日入库"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="0"
                                   FontSize="28"
                                   FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- 今日出库 -->
                <Border Background="{DynamicResource CardFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="20"
                        Margin="8,0,8,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <fa:IconBlock Icon="Truck"
                                         IconFont="Solid"
                                         Width="24"
                                         Height="24"
                                         Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                                         Margin="0,0,8,0"/>
                            <TextBlock Text="今日出库"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="0"
                                   FontSize="28"
                                   FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- 今日来访 -->
                <Border Background="{DynamicResource CardFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="20"
                        Margin="8,0,0,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <fa:IconBlock Icon="UserCheck"
                                         IconFont="Solid"
                                         Width="24"
                                         Height="24"
                                         Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                                         Margin="0,0,8,0"/>
                            <TextBlock Text="今日来访"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="0"
                                   FontSize="28"
                                   FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </UniformGrid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
