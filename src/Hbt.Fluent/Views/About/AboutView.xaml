<UserControl x:Class="Hbt.Fluent.Views.About.AboutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
             xmlns:local="clr-namespace:Hbt.Fluent.Localization"
             Foreground="{DynamicResource TextFillColorPrimaryBrush}"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <ScrollViewer Grid.Row="0" Margin="0,0,0,24" Padding="0,0,24,0">
            <StackPanel>
            <!-- 应用信息卡片 -->
            <Border Background="{DynamicResource CardFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="32"
                    Margin="10"
                    HorizontalAlignment="Stretch">
                    <StackPanel HorizontalAlignment="Center">
                        <!-- Logo/图标 -->
                        <fa:IconBlock Icon="CircleInfo"
                                     IconFont="Solid"
                                     Width="64"
                                     Height="64"
                                     Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                                     HorizontalAlignment="Center"
                                     Margin="0,0,0,16"/>
                        
                        <!-- 应用名称 -->
                        <TextBlock Text="黑冰台管理系统"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>
                        
                        <!-- 版本信息 -->
                        <TextBlock Text="Version 1.0.0"
                                   FontSize="16"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,24"/>
                        
                        <!-- 分隔线 -->
                        <Rectangle Height="1"
                                  Fill="{DynamicResource CardStrokeColorDefaultBrush}"
                                  Margin="0,0,0,24"/>
                        
                        <!-- 描述信息 -->
                        <TextBlock TextWrapping="Wrap"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,0,0,16">
                            <Run Text="{local:Loc Key=about.description}"/>
                        </TextBlock>
                    </StackPanel>
            </Border>

            <!-- 技术信息 -->
            <Border Background="{DynamicResource CardFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="24"
                    Margin="10"
                    HorizontalAlignment="Stretch">
                    <StackPanel>
                        <TextBlock Text="{local:Loc Key=about.technology}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,16"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0"
                                      Text="{local:Loc Key=about.framework}"
                                      Margin="0,0,16,12"
                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1"
                                      Text=".NET 9.0"
                                      Margin="0,0,0,12"/>

                            <TextBlock Grid.Row="1" Grid.Column="0"
                                      Text="{local:Loc Key=about.uiFramework}"
                                      Margin="0,0,16,12"
                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Grid.Row="1" Grid.Column="1"
                                      Text="WPF (Windows Presentation Foundation)"
                                      Margin="0,0,0,12"/>

                            <TextBlock Grid.Row="2" Grid.Column="0"
                                      Text="{local:Loc Key=about.database}"
                                      Margin="0,0,16,12"
                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Grid.Row="2" Grid.Column="1"
                                      Text="SQL Server / SqlSugar ORM"
                                      Margin="0,0,0,12"/>

                            <TextBlock Grid.Row="3" Grid.Column="0"
                                      Text="{local:Loc Key=about.architecture}"
                                      Margin="0,0,16,12"
                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Grid.Row="3" Grid.Column="1"
                                      Text="MVVM (Model-View-ViewModel)"
                                      Margin="0,0,0,12"/>

                            <TextBlock Grid.Row="4" Grid.Column="0"
                                      Text="{local:Loc Key=about.buildDate}"
                                      Margin="0,0,16,0"
                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Grid.Row="4" Grid.Column="1"
                                      x:Name="BuildDateTextBlock"/>
                        </Grid>
                    </StackPanel>
            </Border>

            <!-- 版权信息 -->
            <Border Background="{DynamicResource CardFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="24"
                    Margin="10"
                    HorizontalAlignment="Stretch">
                    <StackPanel>
                        <TextBlock Text="{local:Loc Key=about.copyright}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,12"/>
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                            <Run Text="Copyright © 2025 黑冰台. All rights reserved."/>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
