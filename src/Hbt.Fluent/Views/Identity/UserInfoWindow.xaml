<Window x:Class="Hbt.Fluent.Views.Identity.UserInfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
        xmlns:local="clr-namespace:Hbt.Fluent.Localization"
        xmlns:helpers="clr-namespace:Hbt.Fluent.Helpers"
        Title="用户信息" Height="520" Width="600" 
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize" 
        Background="{DynamicResource LayerFillColorDefaultBrush}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <helpers:EnumToStringConverter x:Key="EnumToStringConverter"/>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <fa:IconBlock
                Icon="User"
                IconFont="Solid"
                Width="24"
                Height="24"
                Margin="0,0,8,0"
                VerticalAlignment="Center"
                Foreground="{DynamicResource AccentFillColorDefaultBrush}"/>
            <TextBlock
                FontSize="20"
                FontWeight="SemiBold"
                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                VerticalAlignment="Center"
                Text="用户信息"/>
        </StackPanel>

        <!-- 内容区域 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 用户ID -->
                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,8" 
                           Text="{local:Loc Key=common.audit.id}"/>
                <TextBlock Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" Margin="0,8"
                           Text="{Binding ViewModel.UserInfo.Id}"/>

                <!-- 用户�?-->
                <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,8"
                           Text="{local:Loc Key=Identity.User.Username}"/>
                <TextBlock Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" Margin="0,8"
                           Text="{Binding ViewModel.UserInfo.Username}"/>

                <!-- 真实姓名 -->
                <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,8"
                           Text="{local:Loc Key=Identity.User.RealName}"/>
                <TextBlock Grid.Row="2" Grid.Column="1" VerticalAlignment="Center" Margin="0,8"
                           Text="{Binding ViewModel.UserInfo.RealName}"/>

                <!-- 邮箱 -->
                <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="0,8"
                           Text="{local:Loc Key=Identity.User.Email}"/>
                <TextBlock Grid.Row="3" Grid.Column="1" VerticalAlignment="Center" Margin="0,8"
                           Text="{Binding ViewModel.UserInfo.Email}"/>

                <!-- 手机�?-->
                <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Margin="0,8"
                           Text="{local:Loc Key=Identity.User.Phone}"/>
                <TextBlock Grid.Row="4" Grid.Column="1" VerticalAlignment="Center" Margin="0,8"
                           Text="{Binding ViewModel.UserInfo.Phone}"/>

                <!-- 用户类型 -->
                <TextBlock Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" Margin="0,8"
                           Text="{local:Loc Key=Identity.User.UserType}"/>
                <TextBlock Grid.Row="5" Grid.Column="1" VerticalAlignment="Center" Margin="0,8"
                           Text="{Binding ViewModel.UserInfo.UserType, Converter={StaticResource EnumToStringConverter}}"/>

                <!-- 性别 -->
                <TextBlock Grid.Row="6" Grid.Column="0" VerticalAlignment="Center" Margin="0,8"
                           Text="{local:Loc Key=Identity.User.UserGender}"/>
                <TextBlock Grid.Row="6" Grid.Column="1" VerticalAlignment="Center" Margin="0,8"
                           Text="{Binding ViewModel.UserInfo.UserGender, Converter={StaticResource EnumToStringConverter}}"/>

                <!-- 状�?-->
                <TextBlock Grid.Row="7" Grid.Column="0" VerticalAlignment="Center" Margin="0,8"
                           Text="{local:Loc Key=Identity.User.UserStatus}"/>
                <TextBlock Grid.Row="7" Grid.Column="1" VerticalAlignment="Center" Margin="0,8"
                           Text="{Binding ViewModel.UserInfo.UserStatus, Converter={StaticResource EnumToStringConverter}}"/>

                <!-- 创建时间 -->
                <TextBlock Grid.Row="8" Grid.Column="0" VerticalAlignment="Center" Margin="0,8"
                           Text="{local:Loc Key=common.audit.created_time}"/>
                <TextBlock Grid.Row="8" Grid.Column="1" VerticalAlignment="Center" Margin="0,8"
                           Text="{Binding ViewModel.UserInfo.CreatedTime, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}"/>

                <!-- 备注 -->
                <TextBlock Grid.Row="9" Grid.Column="0" VerticalAlignment="Top" Margin="0,8"
                           Text="{local:Loc Key=common.audit.remarks}"/>
                <TextBlock Grid.Row="9" Grid.Column="1" VerticalAlignment="Top" Margin="0,8" TextWrapping="Wrap"
                           Text="{Binding ViewModel.UserInfo.Remarks}"/>
            </Grid>
        </ScrollViewer>

        <!-- 按钮区域 -->
        <Grid Grid.Row="2" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button
                Grid.Column="1"
                Width="100"
                Height="36"
                Content="{local:Loc Key=Button.Close}"
                Command="{Binding ViewModel.CloseCommand}"
                CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
        </Grid>
    </Grid>
</Window>
