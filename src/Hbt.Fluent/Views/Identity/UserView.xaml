<UserControl x:Class="Hbt.Fluent.Views.Identity.UserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
             xmlns:local="clr-namespace:Hbt.Fluent.Localization"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 查询�?-->
        <Border Grid.Row="0" Padding="8" Background="{DynamicResource LayerFillColorDefaultBrush}" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="4" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">
                <TextBox Width="220" Margin="0,0,8,0" x:Name="SearchBox" Text="{Binding Keyword, UpdateSourceTrigger=PropertyChanged}">
                    <TextBox.ToolTip><TextBlock Text="{local:Loc Key=common.placeholder.search, Param0Key=Identity.User.Username}"/></TextBox.ToolTip>
                </TextBox>
                <Button Width="80" Margin="0,0,8,0" Command="{Binding QueryCommand}">
                    <StackPanel Orientation="Horizontal"><fa:IconBlock Icon="MagnifyingGlass" IconFont="Solid" Width="14" Height="14" Margin="0,0,6,0"/><TextBlock Text="{local:Loc Key=common.search}"/></StackPanel>
                </Button>
                <Button Width="80" Margin="0,0,8,0" Command="{Binding ResetCommand}">
                    <StackPanel Orientation="Horizontal"><fa:IconBlock Icon="RotateLeft" IconFont="Solid" Width="14" Height="14" Margin="0,0,6,0"/><TextBlock Text="{local:Loc Key=common.reset}"/></StackPanel>
                </Button>
                <Button Width="110" Command="{Binding ToggleAdvancedCommand}">
                    <StackPanel Orientation="Horizontal"><fa:IconBlock Icon="Sliders" IconFont="Solid" Width="14" Height="14" Margin="0,0,6,0"/><TextBlock Text="{local:Loc Key=common.advancedQuery}"/></StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- 工具栏：左侧操作，右对齐功能 -->
        <DockPanel Grid.Row="1" LastChildFill="False" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                <!-- 创建按钮：主要操作，使用 PrimaryButtonStyle -->
                <Button MinWidth="80" Margin="0,0,8,0" Command="{Binding CreateCommand}" Style="{StaticResource PrimaryButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <fa:IconBlock Icon="Plus" IconFont="Solid" Width="14" Height="14" Margin="0,0,6,0"/>
                        <TextBlock Text="{local:Loc Key=common.button.create}"/>
                    </StackPanel>
                </Button>
                <!-- 编辑按钮：次要操作，使用 SecondaryButtonStyle -->
                <Button MinWidth="80" Margin="0,0,8,0" Command="{Binding EditCommand}" Style="{StaticResource SecondaryButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <fa:IconBlock Icon="PenToSquare" IconFont="Solid" Width="14" Height="14" Margin="0,0,6,0"/>
                        <TextBlock Text="{local:Loc Key=common.button.update}"/>
                    </StackPanel>
                </Button>
                <!-- 删除按钮：危险操作，使用 DangerButtonStyle -->
                <Button MinWidth="80" Margin="0,0,8,0" Command="{Binding DeleteCommand}" Style="{StaticResource DangerButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <fa:IconBlock Icon="Trash" IconFont="Solid" Width="14" Height="14" Margin="0,0,6,0"/>
                        <TextBlock Text="{local:Loc Key=common.button.delete}"/>
                    </StackPanel>
                </Button>
                <!-- 导入按钮：次要操作，使用 SecondaryButtonStyle -->
                <Button MinWidth="80" Margin="0,0,8,0" Command="{Binding ImportCommand}" Style="{StaticResource SecondaryButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <fa:IconBlock Icon="FileArrowUp" IconFont="Solid" Width="14" Height="14" Margin="0,0,6,0"/>
                        <TextBlock Text="{local:Loc Key=common.button.import}"/>
                    </StackPanel>
                </Button>
                <!-- 导出按钮：次要操作，使用 SecondaryButtonStyle -->
                <Button MinWidth="80" Margin="0,0,8,0" Command="{Binding ExportCommand}" Style="{StaticResource SecondaryButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <fa:IconBlock Icon="FileArrowDown" IconFont="Solid" Width="14" Height="14" Margin="0,0,6,0"/>
                        <TextBlock Text="{local:Loc Key=common.button.export}"/>
                    </StackPanel>
                </Button>
            </StackPanel>
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                <!-- 刷新按钮：图标按钮，使用 IconButtonStyle -->
                <Button Width="36" Height="36" Margin="0,0,8,0" Command="{Binding LoadCommand}" 
                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                        Style="{StaticResource IconButtonStyle}">
                    <fa:IconBlock Icon="Rotate" IconFont="Solid" Width="18" Height="18"/>
                    <Button.ToolTip>
                        <TextBlock Text="{local:Loc Key=common.button.refresh}"/>
                    </Button.ToolTip>
                </Button>
                <!-- 切换列按钮：图标按钮，使用 IconButtonStyle -->
                <Button Width="36" Height="36" Margin="0,0,8,0" Command="{Binding ToggleColumnsCommand}" 
                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                        Style="{StaticResource IconButtonStyle}">
                    <fa:IconBlock Icon="Columns" IconFont="Solid" Width="18" Height="18"/>
                    <Button.ToolTip>
                        <TextBlock Text="{local:Loc Key=common.toggleColumns}"/>
                    </Button.ToolTip>
                </Button>
                <!-- 切换查询栏按钮：图标按钮，使用 IconButtonStyle -->
                <Button Width="36" Height="36" Command="{Binding ToggleQueryBarCommand}" 
                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                        Style="{StaticResource IconButtonStyle}">
                    <fa:IconBlock Icon="MagnifyingGlass" IconFont="Solid" Width="18" Height="18"/>
                    <Button.ToolTip>
                        <TextBlock Text="{local:Loc Key=common.toggleQueryBar}"/>
                    </Button.ToolTip>
                </Button>
            </StackPanel>
        </DockPanel>

        <DataGrid x:Name="UsersGrid" Grid.Row="2" ItemsSource="{Binding Users}" SelectedItem="{Binding SelectedUser, Mode=TwoWay}"
                  AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn x:Name="colId" Header="{local:Loc Key=common.audit.id}" Binding="{Binding Id}" Width="80"/>
                <DataGridTextColumn x:Name="colUsername" Header="{local:Loc Key=Identity.User.Username}" Binding="{Binding Username}" Width="150"/>
                <!-- Password 列不展示 -->
                <DataGridTextColumn x:Name="colEmail" Header="{local:Loc Key=Identity.User.Email}" Binding="{Binding Email}" Width="200"/>
                <DataGridTextColumn x:Name="colPhone" Header="{local:Loc Key=Identity.User.Phone}" Binding="{Binding Phone}" Width="150"/>
                <DataGridTextColumn x:Name="colRealName" Header="{local:Loc Key=Identity.User.RealName}" Binding="{Binding RealName}" Width="150"/>
                <DataGridTextColumn x:Name="colUserType" Header="{local:Loc Key=Identity.User.UserType}" Binding="{Binding UserType}" Width="120"/>
                <DataGridTextColumn x:Name="colUserGender" Header="{local:Loc Key=Identity.User.UserGender}" Binding="{Binding UserGender}" Width="120"/>
                <DataGridTextColumn x:Name="colUserStatus" Header="{local:Loc Key=Identity.User.UserStatus}" Binding="{Binding UserStatus}" Width="120"/>
                <DataGridTextColumn x:Name="colRemarks" Header="{local:Loc Key=common.audit.remarks}" Binding="{Binding Remarks}" Width="200"/>
                <DataGridTextColumn x:Name="colCreatedBy" Header="{local:Loc Key=common.audit.created_by}" Binding="{Binding CreatedBy}" Width="140"/>
                <DataGridTextColumn x:Name="colCreated" Header="{local:Loc Key=common.audit.created_time}" Binding="{Binding CreatedTime}" Width="180"/>
                <DataGridTextColumn x:Name="colUpdatedBy" Header="{local:Loc Key=common.audit.updated_by}" Binding="{Binding UpdatedBy}" Width="140"/>
                <DataGridTextColumn x:Name="colUpdated" Header="{local:Loc Key=common.audit.updated_time}" Binding="{Binding UpdatedTime}" Width="180"/>
                <DataGridTextColumn x:Name="colIsDeleted" Header="{local:Loc Key=common.audit.is_deleted}" Binding="{Binding IsDeleted}" Width="100"/>
                <DataGridTextColumn x:Name="colDeletedBy" Header="{local:Loc Key=common.audit.deleted_by}" Binding="{Binding DeletedBy}" Width="140"/>
                <DataGridTextColumn x:Name="colDeletedTime" Header="{local:Loc Key=common.audit.deleted_time}" Binding="{Binding DeletedTime}" Width="180"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- 分页 -->
        <DockPanel Grid.Row="3" Margin="0,8,0,0">
            <TextBlock VerticalAlignment="Center" Text="{Binding TotalText}"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                <Button Width="80" Margin="8,0,0,0" Command="{Binding PrevPageCommand}" 
                        Content="{local:Loc Key=common.prevPage}" 
                        Style="{StaticResource TextButtonStyle}"/>
                <TextBlock VerticalAlignment="Center" Margin="8,0" Text="{Binding PageDisplay}"/>
                <Button Width="80" Command="{Binding NextPageCommand}" 
                        Content="{local:Loc Key=common.nextPage}" 
                        Style="{StaticResource TextButtonStyle}"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</UserControl>


