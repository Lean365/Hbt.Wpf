<Window x:Class="Hbt.Fluent.Views.Identity.UserFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
        xmlns:local="clr-namespace:Hbt.Fluent.Localization"
        Title="{Binding Title}" Height="380" Width="520" WindowStartupLocation="Manual"
        ResizeMode="CanResize" Background="{DynamicResource LayerFillColorDefaultBrush}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <!-- 一行两列：每行放置两个 字段组（标签+输入�?-->
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- �?行：用户�?| 姓名 -->
            <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="{local:Loc Key=Identity.User.Username}"/>
            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"/>
            <TextBlock Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" Text="{local:Loc Key=Identity.User.RealName}"/>
            <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding RealName, UpdateSourceTrigger=PropertyChanged}"/>

            <!-- �?行：邮箱 | 手机 -->
            <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="{local:Loc Key=Identity.User.Email}"/>
            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>
            <TextBlock Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" Text="{local:Loc Key=Identity.User.Phone}"/>
            <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"/>

            <!-- �?行（仅新建显示）：密�?| 确认密码 -->
            <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="{local:Loc Key=Identity.User.Password}"
                       Visibility="{Binding IsCreate, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            <PasswordBox Grid.Row="2" Grid.Column="1" x:Name="Pwd" Width="200" Margin="0,8,8,0"
                         Visibility="{Binding IsCreate, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            <TextBlock Grid.Row="2" Grid.Column="2" VerticalAlignment="Center" Text="{local:Loc Key=Identity.User.PasswordConfirm}"
                       Visibility="{Binding IsCreate, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            <PasswordBox Grid.Row="2" Grid.Column="3" x:Name="Pwd2" Width="200" Margin="0,8,0,0"
                         Visibility="{Binding IsCreate, Converter={StaticResource BooleanToVisibilityConverter}}"/>

            <!-- �?行：类型 | 性别 -->
            <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="{local:Loc Key=Identity.User.UserType}"/>
            <ComboBox Grid.Row="3" Grid.Column="1" SelectedValue="{Binding UserType}" SelectedValuePath="Tag" Width="200">
                <ComboBoxItem Tag="0"><TextBlock Text="{local:Loc Key=Identity.User.UserType.System}"/></ComboBoxItem>
                <ComboBoxItem Tag="1"><TextBlock Text="{local:Loc Key=Identity.User.UserType.Normal}"/></ComboBoxItem>
            </ComboBox>
            <TextBlock Grid.Row="3" Grid.Column="2" VerticalAlignment="Center" Text="{local:Loc Key=Identity.User.UserGender}"/>
            <ComboBox Grid.Row="3" Grid.Column="3" SelectedValue="{Binding UserGender}" SelectedValuePath="Tag" Width="200">
                <ComboBoxItem Tag="0"><TextBlock Text="{local:Loc Key=Identity.User.UserGender.Unknown}"/></ComboBoxItem>
                <ComboBoxItem Tag="1"><TextBlock Text="{local:Loc Key=Identity.User.UserGender.Male}"/></ComboBoxItem>
                <ComboBoxItem Tag="2"><TextBlock Text="{local:Loc Key=Identity.User.UserGender.Female}"/></ComboBoxItem>
            </ComboBox>

            <!-- �?行：状�?| 备注 -->
            <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Text="{local:Loc Key=Identity.User.UserStatus}"/>
            <ComboBox Grid.Row="4" Grid.Column="1" SelectedValue="{Binding UserStatus}" SelectedValuePath="Tag" Width="200">
                <ComboBoxItem Tag="0"><TextBlock Text="{local:Loc Key=Identity.User.UserStatus.Normal}"/></ComboBoxItem>
                <ComboBoxItem Tag="1"><TextBlock Text="{local:Loc Key=Identity.User.UserStatus.Disabled}"/></ComboBoxItem>
            </ComboBox>
            <TextBlock Grid.Row="4" Grid.Column="2" VerticalAlignment="Center" Text="{local:Loc Key=common.audit.remarks}"/>
            <TextBox Grid.Row="4" Grid.Column="3" Text="{Binding Remarks}"/>

            <!-- �?行（更新只读显示）：创建/更新审计信息 -->
            <TextBlock Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" Text="{local:Loc Key=common.audit.created_time}"/>
            <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding CreatedTime}" IsReadOnly="True"/>
            <TextBlock Grid.Row="5" Grid.Column="2" VerticalAlignment="Center" Text="{local:Loc Key=common.audit.updated_time}"/>
            <TextBox Grid.Row="5" Grid.Column="3" Text="{Binding UpdatedTime}" IsReadOnly="True"/>
        </Grid>

        <DockPanel Grid.Row="1" Margin="0,16,0,0">
            <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource SystemFillColorCriticalBrush}" Text="{Binding Error}"/>
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                <Button Width="90" Margin="0,0,8,0" IsDefault="True" Command="{Binding SaveCommand}">
                    <StackPanel Orientation="Horizontal"><fa:IconBlock Icon="FloppyDisk" IconFont="Solid" Width="14" Height="14" Margin="0,0,6,0"/><TextBlock Text="{local:Loc Key=common.button.submit}"/></StackPanel>
                </Button>
                <Button Width="90" IsCancel="True" Content="{local:Loc Key=Button.Close}"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>


