<Window x:Class="Hbt.Fluent.Views.Identity.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
        xmlns:helpers="clr-namespace:Hbt.Fluent.Helpers"
        xmlns:local="clr-namespace:Hbt.Fluent.Localization"
        Title="{local:Loc Key=Login.Title}"
        Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="{DynamicResource LayerFillColorDefaultBrush}">
    
    <Window.Resources>
        <helpers:EmptyToVisibilityConverter x:Key="EmptyToVisibilityConverter" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <helpers:InvertedBooleanToVisibilityConverter x:Key="InvertedBooleanToVisibilityConverter" />
        
        <!-- IconBlock 默认样式，确�?IconFont 始终�?Solid -->
        <Style TargetType="fa:IconBlock">
            <Setter Property="IconFont" Value="Solid"/>
        </Style>
    </Window.Resources>
    
    <Border Background="{DynamicResource LayerFillColorDefaultBrush}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="1.2*"/>
            </Grid.ColumnDefinitions>
            
            <!-- 左侧：品牌展示区 -->
            <Border Grid.Column="0"
                    Background="{DynamicResource AccentFillColorDefaultBrush}">
                <Grid>
                    <!-- Logo和文字内�?-->
                    <StackPanel VerticalAlignment="Center" 
                               HorizontalAlignment="Center"
                               Margin="60">
                        <!-- Logo图片 -->
                        <Image Source="pack://application:,,,/Assets/hbt-logo.png"
                               Width="120" 
                               Height="120"
                               Margin="0,0,0,40"
                               Stretch="Uniform">
                            <Image.Effect>
                                <DropShadowEffect BlurRadius="20" 
                                                 Opacity="0.4" 
                                                 Direction="270" 
                                                 ShadowDepth="8"/>
                            </Image.Effect>
                        </Image>
                        
                    <TextBlock Text="{local:Loc Key=Common.CompanyName}"
                                  FontSize="32" 
                                  FontWeight="Bold"
                                  HorizontalAlignment="Center"
                                  Margin="0,0,0,16"
                                  Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}"/>
                        <TextBlock Text="{local:Loc Key=Common.CompanySlogan}"
                                  FontSize="18" 
                                  Foreground="{DynamicResource TextOnAccentFillColorSecondaryBrush}"
                                  HorizontalAlignment="Center"
                                  Opacity="0.9"/>
                        <TextBlock Text="{local:Loc Key=Common.CompanyTagline}" 
                              FontSize="14" 
                                  Foreground="{DynamicResource TextOnAccentFillColorTertiaryBrush}"
                                  HorizontalAlignment="Center"
                                  Margin="0,20,0,0"
                                  Opacity="0.8"/>
                    </StackPanel>
                </Grid>
            </Border>
            
            <!-- 中间分隔�?-->
            <Rectangle Grid.Column="1" 
                      Width="1" 
                      Fill="{DynamicResource CardStrokeColorDefaultBrush}"/>
            
            <!-- 主题切换、语言切换和关闭按钮容�?-->
            <StackPanel Grid.Column="2"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Top"
                       Orientation="Horizontal"
                       Margin="0,4,4,0"
                       Panel.ZIndex="1000">
                <!-- 语言切换菜单 -->
                <Menu>
                    <MenuItem x:Name="LanguageMenuItem"
                             SubmenuOpened="LanguageMenuItem_SubmenuOpened"
                             ToolTip="{Binding LanguageToolTip}"
                             Width="32"
                             Height="32"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                             Cursor="Hand"
                             HorizontalContentAlignment="Center"
                             VerticalContentAlignment="Center">
                        <MenuItem.Header>
                            <fa:IconBlock x:Name="LanguageIcon"
                                         Icon="{x:Static fa:IconChar.Globe}"
                                         FontSize="18"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"
                                         Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </MenuItem.Header>
                        <MenuItem.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}"/>
                            </DataTemplate>
                        </MenuItem.ItemTemplate>
                        <MenuItem.ItemContainerStyle>
                            <Style TargetType="MenuItem">
                                <Setter Property="IsCheckable" Value="True"/>
                                <EventSetter Event="Click" Handler="LanguageMenuItem_ItemClick"/>
                            </Style>
                        </MenuItem.ItemContainerStyle>
                        <MenuItem.Style>
                            <Style TargetType="MenuItem">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="MenuItem">
                                            <Grid>
                                                <Border x:Name="Border" 
                                                        Background="{TemplateBinding Background}"
                                                        CornerRadius="4">
                                                    <ContentPresenter x:Name="HeaderPresenter"
                                                                      Content="{TemplateBinding Header}"
                                                                      ContentTemplate="{TemplateBinding HeaderTemplate}"
                                                                      ContentStringFormat="{TemplateBinding HeaderStringFormat}"
                                                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                                      RecognizesAccessKey="True"
                                                                      SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                                </Border>
                                                <Popup x:Name="PART_Popup"
                                                       AllowsTransparency="True"
                                                       Focusable="False"
                                                       IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                                       PopupAnimation="{DynamicResource {x:Static SystemParameters.MenuPopupAnimationKey}}"
                                                       Placement="Bottom">
                                                    <Border x:Name="SubMenuBorder"
                                                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                                                            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="4"
                                                            Padding="1">
                                                        <ScrollViewer x:Name="SubMenuScrollViewer"
                                                                      Style="{DynamicResource {ComponentResourceKey ResourceId=MenuScrollViewer, TypeInTargetAssembly={x:Type FrameworkElement}}}">
                                                            <ItemsPresenter x:Name="ItemsPresenter"
                                                                            KeyboardNavigation.DirectionalNavigation="Cycle"
                                                                            Grid.IsSharedSizeScope="True"
                                                                            SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                                                                            KeyboardNavigation.TabNavigation="Cycle"/>
                                                        </ScrollViewer>
                                                    </Border>
                                                </Popup>
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsHighlighted" Value="True">
                                                    <Setter TargetName="Border" Property="Background" Value="{DynamicResource ControlAltFillColorQuarternaryBrush}"/>
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorDisabledBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </MenuItem.Style>
                    </MenuItem>
                </Menu>

                <!-- 主题切换图标按钮 -->
                <Button x:Name="ThemeButton"
                       Width="32" 
                       Height="32"
                       Background="Transparent" 
                       BorderThickness="0"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Cursor="Hand"
                       Click="ThemeButton_Click"
                       ToolTip="{Binding ThemeToolTip}"
                       Margin="8,0,0,0">
                    <fa:IconBlock x:Name="ThemeIcon"
                                 Icon="{x:Static fa:IconChar.Palette}"
                                 FontSize="18"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"/>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                               CornerRadius="4">
                                            <ContentPresenter HorizontalAlignment="Center" 
                                                            VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource ControlAltFillColorQuarternaryBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                
                <!-- 关闭按钮 -->
                <Button Width="32" 
                       Height="32"
                       Background="Transparent" 
                       BorderThickness="0"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Cursor="Hand"
                       Click="CloseButton_Click"
                       Margin="8,0,0,0"
                       ToolTip="{local:Loc Key=Common.Close}">
                    <fa:IconBlock Icon="{x:Static fa:IconChar.Xmark}"
                                  FontSize="18"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                               CornerRadius="4">
                                            <ContentPresenter HorizontalAlignment="Center" 
                                                            VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource ControlAltFillColorQuarternaryBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
            
            <!-- 右侧：登录表�?-->
            <Border Grid.Column="2" 
                    Padding="80,60"
                    Background="{DynamicResource LayerFillColorDefaultBrush}">
                <Grid VerticalAlignment="Center">
                <StackPanel>
                        <!-- 登录标题 -->
                        <TextBlock Text="{local:Loc Key=Login.Welcome}"
                                  FontSize="28" 
                                  FontWeight="SemiBold"
                                  Margin="0,0,0,8"
                                  Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        <TextBlock Text="{local:Loc Key=common.placeholder.input, Param0Key=Login.Username}"
                                  FontSize="14" 
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                  Margin="0,0,0,40"/>
                        
                        <!-- 用户名输�?-->
                        <Grid Height="48" Margin="0,0,0,20">
                            <TextBox x:Name="UsernameTextBox"
                                   Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                   FontSize="14"
                                   Padding="0,0,14,0"
                                   BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                   BorderThickness="1"
                                   VerticalContentAlignment="Center"
                                   HorizontalContentAlignment="Left">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="TextBox">
                                                    <Border Background="{DynamicResource LayerFillColorDefaultBrush}"
                                                           BorderBrush="{TemplateBinding BorderBrush}"
                                                           BorderThickness="{TemplateBinding BorderThickness}"
                                                           CornerRadius="4">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="40"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <fa:IconBlock Grid.Column="0"
                                                                         Icon="{x:Static fa:IconChar.User}"
                                                                         FontSize="16"
                                                                         Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                         HorizontalAlignment="Center"
                                                                         VerticalAlignment="Center"/>
                                                            <Border Grid.Column="1" Background="{DynamicResource LayerFillColorDefaultBrush}">
                                                                <ScrollViewer x:Name="PART_ContentHost" 
                                                                            Margin="4,0,0,0"
                                                                            VerticalContentAlignment="Center"
                                                                            HorizontalContentAlignment="Left"
                                                                            Background="Transparent"/>
                                                            </Border>
                                                            <Border Grid.Column="1" Background="Transparent">
                                                                <TextBlock Text="{local:Loc Key=common.placeholder.input, Param0Key=Login.Username}"
                                                                         FontSize="{TemplateBinding FontSize}"
                                                                         Foreground="{DynamicResource TextFillColorDisabledBrush}"
                                                                         VerticalAlignment="Center"
                                                                         HorizontalAlignment="Left"
                                                                         Margin="4,0,0,0"
                                                                         IsHitTestVisible="False">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource AncestorType=TextBox}}" Value="">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource AncestorType=TextBox}}" Value="{x:Null}">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                            </DataTrigger>
                                                                            <MultiDataTrigger>
                                                                                <MultiDataTrigger.Conditions>
                                                                                    <Condition Binding="{Binding Text, RelativeSource={RelativeSource AncestorType=TextBox}}" Value=""/>
                                                                                    <Condition Binding="{Binding IsFocused, RelativeSource={RelativeSource AncestorType=TextBox}}" Value="True"/>
                                                                                </MultiDataTrigger.Conditions>
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                            </MultiDataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                                </TextBlock>
                                                            </Border>
                                                        </Grid>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsFocused" Value="True">
                                                <Setter Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </Grid>
                        
                        <!-- 密码输入 -->
                        <Grid Height="48" Margin="0,0,0,20">
                            <PasswordBox x:Name="PasswordBox"
                                       PasswordChanged="PasswordBox_PasswordChanged"
                                       GotFocus="PasswordBox_GotFocus"
                                       LostFocus="PasswordBox_LostFocus"
                                       FontSize="14"
                                       Padding="0,0,14,0"
                                       BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                       BorderThickness="1"
                                       VerticalContentAlignment="Center"
                                       HorizontalContentAlignment="Left">
                                <PasswordBox.Style>
                                    <Style TargetType="PasswordBox">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="PasswordBox">
                                                    <Border Background="{DynamicResource LayerFillColorDefaultBrush}"
                                                           BorderBrush="{TemplateBinding BorderBrush}"
                                                           BorderThickness="{TemplateBinding BorderThickness}"
                                                           CornerRadius="4">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="40"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <fa:IconBlock Grid.Column="0"
                                                                         Icon="{x:Static fa:IconChar.Lock}"
                                                                         FontSize="16"
                                                                         Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                         HorizontalAlignment="Center"
                                                                         VerticalAlignment="Center"/>
                                                            <Border Grid.Column="1" Background="{DynamicResource LayerFillColorDefaultBrush}">
                                                                <ScrollViewer x:Name="PART_ContentHost" 
                                                                            Margin="4,0,0,0"
                                                                            VerticalContentAlignment="Center"
                                                                            HorizontalContentAlignment="Left"
                                                                            Background="Transparent"/>
                                                            </Border>
                                                            <Border Grid.Column="1" Background="Transparent">
                                                                <TextBlock x:Name="PasswordPlaceholder"
                                                                         Text="{local:Loc Key=common.placeholder.input, Param0Key=Login.Password}"
                                                                         FontSize="{TemplateBinding FontSize}"
                                                                         Foreground="{DynamicResource TextFillColorDisabledBrush}"
                                                                         VerticalAlignment="Center"
                                                                         HorizontalAlignment="Left"
                                                                         Margin="4,0,0,0"
                                                                         IsHitTestVisible="False"
                                                                         Visibility="Visible"/>
                                                            </Border>
                                                        </Grid>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsFocused" Value="True">
                                                <Setter Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </PasswordBox.Style>
                            </PasswordBox>
                        </Grid>
                        
                        <!-- 记住密码和忘记密�?-->
                        <Grid Margin="0,0,0,24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0"
                                     Content="{local:Loc Key=Login.RememberMe}" 
                                     FontSize="14"
                                     IsChecked="{Binding RememberMe}"
                                     VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                     Text="{local:Loc Key=Login.Forgot}"
                                  FontSize="14"
                                     Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                     Cursor="Hand"
                                     VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource AccentTextFillColorSecondaryBrush}"/>
                                                <Setter Property="TextDecorations" Value="Underline"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                        
                        <!-- 错误消息 -->
                        <Border Margin="0,0,0,20"
                                Background="{DynamicResource SystemFillColorCautionBackgroundBrush}"
                                Padding="12,8"
                                BorderBrush="{DynamicResource SystemFillColorCriticalBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Visibility="{Binding ErrorMessage, Converter={StaticResource EmptyToVisibilityConverter}}">
                        <TextBlock Text="{Binding ErrorMessage}" 
                                      Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                                  FontSize="13"
                                      TextWrapping="Wrap"/>
                        </Border>
                        
                        <!-- 登录按钮 -->
                        <Button Height="48"
                              FontSize="16"
                              FontWeight="SemiBold"
                              Background="{DynamicResource AccentFillColorDefaultBrush}"
                              Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}"
                              BorderThickness="0"
                              Cursor="Hand"
                              Command="{Binding LoginCommand}">
                            <Grid>
                                <!-- 登录文本 -->
                                <TextBlock Text="{local:Loc Key=Login.Button}"
                                         HorizontalAlignment="Center" 
                                         VerticalAlignment="Center"
                                         Visibility="{Binding IsLoading, Converter={StaticResource InvertedBooleanToVisibilityConverter}}"/>
                                
                                <!-- 加载动画 -->
                                <StackPanel Orientation="Horizontal"
                                          HorizontalAlignment="Center" 
                                          VerticalAlignment="Center"
                                          Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <fa:IconBlock x:Name="LoadingIcon"
                                                Icon="CircleNotch"
                                                IconFont="Solid"
                                                Width="16"
                                                Height="16"
                                                FontSize="16"
                                                Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                        <fa:IconBlock.RenderTransform>
                                            <RotateTransform CenterX="8" CenterY="8"/>
                                        </fa:IconBlock.RenderTransform>
                                        <fa:IconBlock.Style>
                                            <Style TargetType="fa:IconBlock" BasedOn="{StaticResource {x:Type fa:IconBlock}}">
                                                <Setter Property="IconFont" Value="Solid"/>
                                                <Style.Triggers>
                                                    <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                                        <BeginStoryboard>
                                                            <Storyboard RepeatBehavior="Forever">
                                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                               From="0" To="360" Duration="0:0:0.8"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </EventTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </fa:IconBlock.Style>
                                    </fa:IconBlock>
                                    <TextBlock Text="{local:Loc Key=Login.Loading}"
                                             Margin="8,0,0,0"
                                             FontSize="16"
                                             VerticalAlignment="Center"
                                             Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}"/>
                                </StackPanel>
                            </Grid>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                       CornerRadius="4"
                                                       Padding="20,12">
                                                    <ContentPresenter HorizontalAlignment="Center" 
                                                                    VerticalAlignment="Center" />
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource AccentFillColorSecondaryBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource AccentFillColorTertiaryBrush}"/>
                                            <Setter Property="Opacity" Value="0.9"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Background" Value="{DynamicResource ControlFillColorDisabledBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorDisabledBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>